# -----------------------------------------------------------------------------
# MyHome 임대주택 맞춤형 알림 서비스 환경 변수 설정
# 이 파일을 복사해서 '.env' 파일을 만든 뒤 본인의 값을 입력해 주세요.
# -----------------------------------------------------------------------------

# 1. Google AI Studio API 키 (무료 티어 사용 가능)
# 발급처: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# 2. 텔레그램 봇 토큰
# 발급처: 텔레그램에서 @BotFather를 찾아 /newbot 입력 후 발급받은 토큰
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# 3. 알림을 수신할 본인의 텔레그램 Chat ID
# 확인 방법: 발급받은 봇에게 메시지를 보낸 후, 웹브라우저에서 아래 주소 호출:
# https://api.telegram.org/bot<TELEGRAM_BOT_TOKEN>/getUpdates
# 결과 JSON에서 message.chat.id 필드 값을 확인하여 입력합니다.
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 마이홈 릴레이 서버 설정 (GitHub Actions용, 로컬에서는 불필요)
# MYHOME_RELAY_URL=http://woojoo720.dothome.co.kr/myhome_relay.php
# MYHOME_RELAY_KEY=hangbok_relay_2026
